# App
APP_BIND=127.0.0.1
APP_PORT=3002

# LLM provider: anthropic, openai, gemini, or aistudio
LLM_PROVIDER=anthropic

# 태스크별 provider override (선택). 비워두면 LLM_PROVIDER 사용.
# synthesis = 2-10/3-10 종합(strength/growthVision). 길고 구체성·문체 정교함이
# 필요한 태스크라 모델 분리하기 좋음. 예: LLM_PROVIDER_SYNTHESIS=gemini
LLM_PROVIDER_SYNTHESIS=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AI Studio
AISTUDIO_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Qrius (LG Academy SSO) — gates the whole app via src/proxy.ts
# QRIUS_MOCK=1 skips the real Qrius round-trip and logs in as QRIUS_MOCK_USERID.
# Use it for local dev until CNS issues the userinfo URL.
QRIUS_MOCK=1
QRIUS_MOCK_USERID=dev-user

# QRIUS_STUB=1 enables dev-only stub Qrius endpoints (/api/auth/qrius/stub/)
# so the real non-mock flow can be tested locally. NEVER set this in production.
QRIUS_STUB=

# Signs the local session cookie. Generate with: openssl rand -hex 32
# Required in every mode (incl. mock). Min 16 chars.
QRIUS_SESSION_SECRET=

# Where Qrius sends the browser back to. Must match the VendorURL given to CNS.
# Local: http://localhost:3002/api/auth/qrius/callback
QRIUS_REDIRECT_URI=http://localhost:3002/api/auth/qrius/callback

# Qrius login page (from CNS email). Only used when QRIUS_MOCK is not 1.
QRIUS_AUTH_URL=https://www.lgacademy.com/login/index.php

# Qrius user-info API — CNS issues this AFTER the data scope is agreed.
# Leave empty until then; real (non-mock) login will fail without it.
QRIUS_USERINFO_URL=

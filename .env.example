# App
APP_BIND=127.0.0.1
APP_PORT=3002

# LLM provider: anthropic, openai, gemini, or aistudio
LLM_PROVIDER=anthropic

# 태스크별 provider override (선택). 비워두면 LLM_PROVIDER 사용.
# synthesis = 2-10/3-10 종합(strength/growthVision). 길고 구체성·문체 정교함이
# 필요한 태스크라 모델 분리하기 좋음. 예: LLM_PROVIDER_SYNTHESIS=gemini
LLM_PROVIDER_SYNTHESIS=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LG AI Studio (aistudio.singlex.com)
# Auth flow: POST /genai/auth/token {ID, Password} → JWT + RefreshToken.
# Bearer JWT on /genai/{api_code}/prompt/{idx} with body {empNo, historyId, parameters[]}.
# Verify response shapes with the dev probe before flipping LLM_PROVIDER=aistudio:
#   GET /api/dev/aistudio-probe
AISTUDIO_BASE_URL=https://aistudio.singlex.com
AISTUDIO_WORKSPACE_ID=
AISTUDIO_API_KEY=
# Single code (back-compat). For quota failover, prefer AISTUDIO_API_CODES below.
AISTUDIO_API_CODE=
# Pool of API codes for round-robin + quota failover (comma-separated, no spaces).
# When a code hits its per-minute or daily token cap the provider rotates to the
# next one. Takes precedence over AISTUDIO_API_CODE when set.
#   e.g. AISTUDIO_API_CODES=LG_BOOK_01,LG_BOOK_02,...,LG_BOOK_10
AISTUDIO_API_CODES=
AISTUDIO_PROMPT_INDEX=1
AISTUDIO_EMP_NO=
# Dual-model split (optional). Route the frequent L-OWL one-liner tasks
# (judgeBranch, reflectShort, rephraseLight, comfortReassure, reflectPoetic,
# reflectValues, reflectStrength, extractKeyword, observePattern) to a cheaper /
# faster model on a separate API code, while summaries + result-page synthesis
# stay on AISTUDIO_API_CODES. Bind this code to e.g. Gemini Flash on the AI Studio
# dashboard. Comma-separated pool, same rotation/failover as the heavy pool.
# When unset, all tasks use AISTUDIO_API_CODES (unchanged behaviour).
#   e.g. AISTUDIO_LIGHT_API_CODES=GEMINI_FLASH
AISTUDIO_LIGHT_API_CODES=
# Prompt index for the light code (defaults to AISTUDIO_PROMPT_INDEX).
AISTUDIO_LIGHT_PROMPT_INDEX=
# Concurrency gate for the light tier (own budget; defaults to AISTUDIO_MAX_CONCURRENCY).
AISTUDIO_LIGHT_MAX_CONCURRENCY=
# Concurrency gate — the upstream AI Studio account tops out at ~20 simultaneous
# requests; past that it returns 500s (not queued). We cap concurrent upstream
# calls per process and queue the rest. PER PROCESS: effective ceiling is this
# value × replica count (prod ≈ 3 replicas), so keep value×replicas under ~20.
# Set very high to disable the gate.
AISTUDIO_MAX_CONCURRENCY=5
# Max time a queued request waits for a slot before returning 429 (busy, retry).
# Keep under the nginx proxy_read_timeout so a queued request never 504s.
AISTUDIO_QUEUE_TIMEOUT_MS=20000
# Retries (with backoff) on a transient upstream 5xx/429 before giving up.
AISTUDIO_OVERLOAD_RETRIES=2

# Async LLM queue — when =1, POST /api/v3/llm enqueues the work and returns a
# jobId immediately; the client polls GET /api/v3/llm/jobs?id=... for the result.
# Nothing holds the HTTP connection open, so users wait in line instead of timing
# out under load. (Sync default when unset: POST blocks and returns the result.)
# ⚠️ IN-MEMORY / PER PROCESS: with multiple replicas, enqueue + polls for one job
# must hit the same replica — configure nginx sticky sessions (ip_hash or a
# sticky cookie). Jobs are lost on restart/deploy.
LLM_ASYNC=0
# Max jobs run concurrently per process. Keep ≤ AISTUDIO_MAX_CONCURRENCY (under
# async, the queue is the concurrency control). value × replicas ≈ upstream load.
LLM_QUEUE_CONCURRENCY=5
# How long (ms) a finished job's result is kept for polling before cleanup.
LLM_JOB_TTL_MS=120000

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Qrius (LG Academy SSO) — gates the whole app via src/proxy.ts
# QRIUS_MOCK=1 skips the real Qrius round-trip and logs in as QRIUS_MOCK_USERID.
# Use it for local dev until CNS issues the userinfo URL.
QRIUS_MOCK=1
QRIUS_MOCK_USERID=dev-user

# QRIUS_STUB=1 enables dev-only stub Qrius endpoints (/api/auth/qrius/stub/)
# so the real non-mock flow can be tested locally. NEVER set this in production.
QRIUS_STUB=

# Signs the local session cookie. Generate with: openssl rand -hex 32
# Required in every mode (incl. mock). Min 16 chars.
QRIUS_SESSION_SECRET=

# Where Qrius sends the browser back to. Must match the VendorURL given to CNS.
# Local: http://localhost:3002/api/auth/qrius/callback
QRIUS_REDIRECT_URI=http://localhost:3002/api/auth/qrius/callback

# Qrius login page (from CNS email). Only used when QRIUS_MOCK is not 1.
QRIUS_AUTH_URL=https://www.lgacademy.com/login/index.php

# Qrius user-info API — CNS issues this AFTER the data scope is agreed.
# Leave empty until then; real (non-mock) login will fail without it.
QRIUS_USERINFO_URL=

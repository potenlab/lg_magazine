# App
APP_BIND=127.0.0.1
APP_PORT=3002

# LLM provider: anthropic, openai, gemini, or aistudio
LLM_PROVIDER=anthropic

# 태스크별 provider override (선택). 비워두면 LLM_PROVIDER 사용.
# synthesis = 2-10/3-10 종합(strength/growthVision). 길고 구체성·문체 정교함이
# 필요한 태스크라 모델 분리하기 좋음. 예: LLM_PROVIDER_SYNTHESIS=gemini
LLM_PROVIDER_SYNTHESIS=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AI Studio
AISTUDIO_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

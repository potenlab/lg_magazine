# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# Claude Code workspace config (per-machine)
.claude/

# JPEG is the *served* format (chapter backgrounds) after the LG WAF was
# found to block .webp and .avif extensions — see docs/diagnose_webp_400.md.
# .jpg files in this dir are committed as production assets.
/public/vision_express/common/background_backup/
/public/vision_express/common/backup/

# Keep small SVG/icon assets that have no webp version
!/public/vision_express/common/*.svg

# Font ttf files are required at runtime by react-pdf (browser PDF
# generation), so they must be committed even though woff2 covers the
# in-page web font use case.

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# nested standalone repo (separate project, intentionally not tracked here)
/lg-inhwawon/

# project uses npm — do not track stray bun lockfile
bun.lock

# graphify per-machine runtime state (absolute paths)
graphify-out/.graphify_python
graphify-out/.graphify_root

# local reference material (separate project copy, not part of this repo)
/docs/reference/

# pre-compressed sibling files (generated by scripts/precompress-assets.sh at deploy time)
public/**/*.gz
public/**/*.br
.next/static/**/*.gz
.next/static/**/*.br
.tokensave

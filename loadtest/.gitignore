# Track only the k6 scripts + the final report. Everything else is either a
# regenerable test artifact (results/, reports/) OR sensitive (cookies.json
# holds live production session tokens when the load-test scripts are run).
*
!.gitignore
!stress-test.js
!realistic-stress-test.js
!proof-api-only.js
!reports/
reports/*
!reports/final-report.pdf
